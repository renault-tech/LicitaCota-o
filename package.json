{
  "name": "licitapreco",
  "version": "0.1.0",
  "private": true,
  "description": "LicitaPreço — Sistema Web de Pesquisa de Preços para Licitações (Lei 14.133/2021 + IN SEGES/ME 65/2021)",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r --filter @licitapreco/shared build && pnpm -r --filter @licitapreco/api build && pnpm -r --filter @licitapreco/web build",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @licitapreco/api dev",
    "dev:web": "pnpm --filter @licitapreco/web dev",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "pnpm -r test",
    "prisma:generate": "pnpm --filter @licitapreco/api prisma:generate",
    "prisma:migrate": "pnpm --filter @licitapreco/api prisma:migrate",
    "seed": "pnpm --filter @licitapreco/api seed",
    "create-admin": "pnpm --filter @licitapreco/api create-admin",
    "reset-senha": "pnpm --filter @licitapreco/api reset-senha"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
